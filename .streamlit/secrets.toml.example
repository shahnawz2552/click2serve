# Click2Serve secrets template
#
# Copy this file to `.streamlit/secrets.toml` (gitignored) and fill in real
# values. The same TOML works locally and on Streamlit Community Cloud
# (paste it into Settings → Secrets in the cloud dashboard).

[supabase]
# Your Supabase project URL.
# Find it at: Supabase dashboard → Project settings → API → Project URL
url = "https://YOUR-PROJECT-REF.supabase.co"

# The anon (public) key. Safe to expose to the client because RLS protects
# the data — but we still keep it in secrets, never in source.
# Find it at: Supabase dashboard → Project settings → API → Project API keys → anon public
key = "eyJhbGc...your-anon-key..."

# Storage bucket name for customer document uploads. Must already exist
# in Supabase Storage. Create it as a PRIVATE bucket.
storage_bucket = "click2serve-documents"


[callmebot]
# CallMeBot WhatsApp API key. See https://www.callmebot.com/blog/free-api-whatsapp-messages/
# For each phone you want to receive messages, that phone must first send
# "I allow callmebot to send me messages" to CallMeBot's WhatsApp number.
# CallMeBot then issues an api_key tied to that phone.
#
# In practice, for a single-shop deployment, this is the OWNER's api_key
# and the owner forwards alerts to customers manually. For full per-customer
# delivery, swap to Twilio or Meta WhatsApp Business API.
api_key = "1234567"
